{% liquid
  assign collection_url = routes.collections_url | append: '/coleccion-otono-invierno-2026'
  assign about_url = routes.root_url | append: '#conocenos'
  assign vestidor_url = '/pages/vestidor'
  assign favorites_url = '/pages/favoritos'

  assign color_option = blank
  assign color_option_position = 0
  assign size_option = blank
  assign size_option_position = 0
  for option in product.options_with_values
    assign option_name = option.name | downcase
    if option_name contains 'color' or option_name contains 'colour'
      assign color_option = option
      assign color_option_position = forloop.index
    elsif option_name contains 'talla' or option_name contains 'size'
      assign size_option = option
      assign size_option_position = forloop.index
    endif
  endfor

  assign selected_color_name = ''
  assign selected_color_display = ''
  if color_option != blank
    assign selected_color_name = color_option.values.first
    assign selected_color_display = selected_color_name
    if selected_color_name == 'Black'
      assign selected_color_display = 'Negro'
    endif
  endif

  assign clean_description = product.description | strip_html | strip
  assign description_text = clean_description | replace: 'Descripción:', '' | strip
  assign composition_text = 'A confirmar.'
  if clean_description contains 'Composición:'
    assign description_text = clean_description | split: 'Composición:' | first | replace: 'Descripción:', '' | strip
    assign composition_text = clean_description | split: 'Composición:' | last | strip
  elsif clean_description contains 'Composicion:'
    assign description_text = clean_description | split: 'Composicion:' | first | replace: 'Descripción:', '' | strip
    assign composition_text = clean_description | split: 'Composicion:' | last | strip
  endif
%}

<nav class="nav nav--transparent nav--catalog" id="mainNav">
  <div class="nav__inner">
    <div class="nav__left" id="navLinks">
      <a href="{{ collection_url }}" class="underlined">Colección</a>
      <a href="{{ about_url }}">Conócenos</a>
      <a href="{{ vestidor_url }}">Vestidor™</a>
    </div>
    <button class="nav__hamburger" type="button" onclick="toggleMobileMenu()" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>
    <a href="{{ routes.root_url }}" class="nav__logo">
      <img src="{{ 'trame_horizontal-black.svg' | asset_url }}" alt="{{ shop.name | escape }}" width="1115" height="142">
    </a>
    <div class="nav__right">
      <a href="{{ routes.search_url }}" title="Buscar">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </a>
      <a href="{{ routes.account_url }}" title="Cuenta">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="{{ favorites_url }}" title="Favoritos">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" title="Carrito" class="nav__cart">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {% if cart.item_count > 0 %}<span class="nav__cart-dot"></span>{% endif %}
      </a>
    </div>
  </div>
</nav>

<div class="nav__mobile-menu" id="mobileMenu">
  <a href="{{ collection_url }}" class="underlined">Colección</a>
  <a href="{{ about_url }}">Conócenos</a>
  <a href="{{ vestidor_url }}">Vestidor™</a>
  <hr>
  <a href="{{ favorites_url }}">Favoritos</a>
  <a href="{{ routes.search_url }}">Buscar</a>
  <a href="{{ routes.cart_url }}">Carrito</a>
</div>

<main class="pdp" data-pdp data-color-position="{{ color_option_position }}" data-size-position="{{ size_option_position }}">
  <section class="pdp-gallery" id="pdpGallery">
    <div class="pdp-gallery__pair pdp-gallery__pair--single" data-pdp-gallery-track>
      {% if color_option != blank %}
        {% liquid
          assign color_value = color_option.values.first
          assign color_slug = color_value | handleize
          if color_slug == 'black'
            assign color_slug = 'negro'
          elsif color_slug == 'verde-pacay' or color_slug == 'verde-botella'
            assign color_slug = 'verde'
          elsif color_slug == 'gris-oscuro'
            assign color_slug = 'gris'
          elsif color_slug == 'azul-oscuro'
            assign color_slug = 'azul'
          elsif color_slug == 'perla'
            assign color_slug = 'blanco'
          endif
          assign color_order_name = color_value | replace: ' ', '_' | append: '_0'
          assign color_asset_name = product.handle | append: '-' | append: color_slug | append: '.png'
          assign color_image_url = color_asset_name | asset_url
        %}
        <img src="{{ color_image_url }}" alt="{{ color_order_name | escape }}" width="1200" height="1500" data-frame="product" data-pdp-hero-image>
      {% elsif product.featured_media.preview_image != blank %}
        <img src="{{ product.featured_media.preview_image | image_url: width: 1400 }}" alt="{{ product.title | escape }}" width="{{ product.featured_media.preview_image.width }}" height="{{ product.featured_media.preview_image.height }}" data-frame="product" data-pdp-hero-image>
      {% else %}
        {% assign fallback_asset = product.handle | append: '.png' %}
        <img src="{{ fallback_asset | asset_url }}" alt="{{ product.title | escape }}" width="1200" height="1500" data-frame="product" data-pdp-hero-image>
      {% endif %}
    </div>
    <button class="pdp-gallery__control pdp-gallery__control--prev" type="button" aria-label="Foto anterior" data-pdp-gallery-prev hidden>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </button>
    <button class="pdp-gallery__control pdp-gallery__control--next" type="button" aria-label="Foto siguiente" data-pdp-gallery-next hidden>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>
    <div class="pdp-gallery__dots" data-pdp-gallery-dots hidden></div>
  </section>

  <section class="pdp-info" id="pdpInfo">
    <h1 class="pdp-info__title">{{ product.title | upcase }}</h1>
    <div class="pdp-info__price">{{ product.price | money }}</div>

    {% form 'product', product, class: 'pdp-form' %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-product-variant-id>

      {% if color_option != blank %}
        <div class="pdp-info__color-label">
          Color: <span id="colorName" data-pdp-color-label>{{ selected_color_display }}</span>
        </div>
        <div class="pdp-info__thumbs" id="colorSwatches">
          {% for color_value in color_option.values %}
            {% liquid
              assign color_slug = color_value | handleize
              assign color_display = color_value
              if color_value == 'Black'
                assign color_display = 'Negro'
              endif
              if color_slug == 'black'
                assign color_slug = 'negro'
              elsif color_slug == 'verde-pacay' or color_slug == 'verde-botella'
                assign color_slug = 'verde'
              elsif color_slug == 'gris-oscuro'
                assign color_slug = 'gris'
              elsif color_slug == 'azul-oscuro'
                assign color_slug = 'azul'
              elsif color_slug == 'perla'
                assign color_slug = 'blanco'
              endif
              assign color_order_name = color_value | replace: ' ', '_' | append: '_0'
              assign color_asset_name = product.handle | append: '-' | append: color_slug | append: '.png'
              assign color_image_url = color_asset_name | asset_url
            %}
            <button class="thumb{% if forloop.first %} active{% endif %}" type="button" data-pdp-color="{{ color_value | escape }}" data-pdp-color-display="{{ color_display | escape }}" data-pdp-image="{{ color_image_url }}" title="{{ color_display | escape }}">
              <img src="{{ color_image_url }}" alt="{{ color_display | escape }}" width="120" height="150" loading="lazy">
            </button>
          {% endfor %}
        </div>
      {% endif %}

      <div class="pdp-desc-short">
        {{ description_text }}
      </div>

      {% if size_option != blank %}
        {% assign ordered_size_values = 'XS|S|M|L|XL|XXL|24|26|28|30|32|34|36|38|40' | split: '|' %}
        {% assign ordered_size_lookup = '|XS|S|M|L|XL|XXL|24|26|28|30|32|34|36|38|40|' %}
        <div class="pdp-size__select" id="sizeSelect" data-pdp-size-select>
          <button class="pdp-size__combobox" id="sizeCombobox" type="button" role="combobox" aria-expanded="false" data-pdp-size-toggle>
            <span id="sizeComboboxLabel" data-pdp-size-label>Selecciona una talla</span>
          </button>
          <div class="pdp-size__listbox" role="listbox">
            {% for ordered_size in ordered_size_values %}
              {% if size_option.values contains ordered_size %}
                <button class="pdp-size__option" type="button" data-pdp-size="{{ ordered_size | escape }}">{{ ordered_size }}</button>
              {% endif %}
            {% endfor %}
            {% for size_value in size_option.values %}
              {% assign size_lookup_key = '|' | append: size_value | append: '|' %}
              {% unless ordered_size_lookup contains size_lookup_key %}
                <button class="pdp-size__option" type="button" data-pdp-size="{{ size_value | escape }}">{{ size_value }}</button>
              {% endunless %}
            {% endfor %}
          </div>
        </div>
        <div class="pdp-size__error" id="sizeError" data-pdp-size-error>Por favor selecciona una talla</div>
      {% endif %}

      <button class="pdp-cta" type="submit" {% unless product.available %}disabled{% endunless %}>
        {% if product.available %}Añadir al Carrito{% else %}Próximamente{% endif %}
      </button>
    {% endform %}

    <a class="pdp-stylewith" href="{{ vestidor_url }}">Añadir al Vestidor™</a>

    <details class="pdp-accordion" open>
      <summary>Composición</summary>
      <div class="pdp-accordion__panel">
        {{ composition_text }}
      </div>
    </details>

    <details class="pdp-accordion" open>
      <summary>Cuidados</summary>
      <div class="pdp-accordion__panel">
        Lavar a mano o en ciclo delicado con agua fría.<br>
        No usar blanqueador. No retorcer.<br>
        Secar a la sombra sobre superficie plana.<br>
        Planchar a baja temperatura por el reverso.
      </div>
    </details>

    <details class="pdp-accordion" open>
      <summary>Envío y devoluciones</summary>
      <div class="pdp-accordion__panel">
        A confirmar.
      </div>
    </details>
  </section>

  <nav class="pdp-breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Inicio</a><span>›</span>
    <a href="{{ collection_url }}">Colección</a><span>›</span>
    <span class="pdp-breadcrumb__last">{{ product.title | upcase }}</span>
  </nav>

  <script type="application/json" data-pdp-variants>
    {{ product.variants | json }}
  </script>
  <script type="application/json" data-pdp-media>
    [
      {% assign media_index = 0 %}
      {% for media in product.media %}
        {% if media.media_type == 'image' and media.preview_image != blank %}
          {% if media_index > 0 %},{% endif %}
          {
            "url": {{ media.preview_image | image_url: width: 1800 | json }},
            "thumb": {{ media.preview_image | image_url: width: 240 | json }},
            "alt": {{ media.alt | default: media.preview_image.alt | default: product.title | json }},
            "filename": {{ media.preview_image.src | split: '/' | last | split: '?' | first | json }},
            "width": {{ media.preview_image.width | json }},
            "height": {{ media.preview_image.height | json }}
          }
          {% assign media_index = media_index | plus: 1 %}
        {% endif %}
      {% endfor %}
    ]
  </script>
</main>

{% schema %}
{
  "name": "Casa Trame Product",
  "settings": [],
  "presets": [
    {
      "name": "Casa Trame Product"
    }
  ]
}
{% endschema %}
