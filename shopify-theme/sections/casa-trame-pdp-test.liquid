<script>
  (() => {
    const root = document.querySelector('[data-ct-mm-pdp="{{ section.id }}"]');
    if (!root) return;

    const galleryImages = Array.from(root.querySelectorAll('[data-ct-gallery-image]'));
    const colorLabel = root.querySelector('[data-ct-color-label]');
    const colorButtons = Array.from(root.querySelectorAll('[data-ct-gallery]'));
    const sizeButtons = Array.from(root.querySelectorAll('[data-ct-size]'));
    const dialog = root.querySelector('[data-ct-mm-dialog]');
    const zoomedImage = root.querySelector('[data-ct-mm-zoomed]');
    const closeButton = root.querySelector('[data-ct-mm-close]');
    const productTitle = {{ product_title | json }};

    colorButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const urls = button.dataset.ctGallery.split('|').filter(Boolean);
        const label = button.dataset.ctColorLabelValue || '';

        colorButtons.forEach((item) => {
          const isActive = item === button;
          item.classList.toggle('is-active', isActive);
          item.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });

        if (colorLabel) colorLabel.textContent = label;

        galleryImages.forEach((image, index) => {
          const nextUrl = urls[index] || urls[0];
          if (!nextUrl) return;
          image.src = nextUrl;
          image.alt = productTitle + ' en ' + label.toLowerCase() + ', vista ' + String(index + 1);
        });
      });
    });

    sizeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        sizeButtons.forEach((item) => {
          item.classList.toggle('is-active', item === button);
          item.setAttribute('aria-pressed', item === button ? 'true' : 'false');
        });
      });
    });

    root.querySelectorAll('[data-ct-zoom-image]').forEach((button) => {
      button.addEventListener('click', () => {
        const image = button.querySelector('img');
        if (!image || !dialog || !zoomedImage || typeof dialog.showModal !== 'function') return;
        zoomedImage.src = image.src;
        zoomedImage.alt = image.alt;
        dialog.showModal();
      });
    });

    if (closeButton && dialog) {
      closeButton.addEventListener('click', () => dialog.close());
      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) dialog.close();
      });
    }
  })();
</script>

