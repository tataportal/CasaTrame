<script>
  (() => {
    const root = document.querySelector('[data-ct-mm-pdp="{{ section.id }}"]');
    if (!root) return;

    const productTitle = {{ product_title | json }};
    const galleryTrack = root.querySelector('[data-ct-gallery-track]');
    const slides = Array.from(root.querySelectorAll('.ct-mm-slide'));
    const thumbs = Array.from(root.querySelectorAll('.ct-mm-thumb'));
    const dots = Array.from(root.querySelectorAll('.ct-mm-pagination button'));
    const galleryImages = Array.from(root.querySelectorAll('[data-ct-gallery-image]'));
    const thumbImages = thumbs.map((thumb) => thumb.querySelector('img')).filter(Boolean);
    const colorButtons = Array.from(root.querySelectorAll('[data-ct-gallery]'));
    const colorLabel = root.querySelector('[data-ct-color-label]');
    const mobileColor = root.querySelector('[data-ct-mobile-color]');
    const sizeButtons = Array.from(root.querySelectorAll('[data-ct-size-option]'));
    const addButton = root.querySelector('.ct-mm-add');
    const sizeError = root.querySelector('[data-ct-size-error]');
    const description = root.querySelector('.ct-mm-description');
    const descriptionText = root.querySelector('[data-ct-description]');
    const descriptionToggle = root.querySelector('[data-ct-description-toggle]');
    const waitlistEmail = root.querySelector('[data-ct-waitlist-email]');
    const sizeModal = root.querySelector('[data-ct-size-modal]');
    const openSize = root.querySelector('[data-ct-open-size]');
    const closeSize = root.querySelector('[data-ct-close-size]');
    const zoomDialog = root.querySelector('[data-ct-mm-dialog]');
    const zoomedImage = root.querySelector('[data-ct-mm-zoomed]');
    const closeZoom = root.querySelector('[data-ct-mm-close]');

    let activeImageIndex = 0;
    let suppressZoomUntil = 0;
    const isMobileGallery = () => window.matchMedia('(max-width: 980px)').matches;

    const setActiveImage = (index, options = {}) => {
      if (!slides.length) return;
      activeImageIndex = (index + slides.length) % slides.length;
      slides.forEach((slide, slideIndex) => slide.classList.toggle('is-active', slideIndex === activeImageIndex));
      thumbs.forEach((thumb, thumbIndex) => thumb.classList.toggle('is-active', thumbIndex === activeImageIndex));
      dots.forEach((dot, dotIndex) => dot.classList.toggle('is-active', dotIndex === activeImageIndex));

      if (galleryTrack && isMobileGallery() && !options.skipScroll) {
        galleryTrack.scrollTo({
          left: galleryTrack.clientWidth * activeImageIndex,
          behavior: options.immediate ? 'auto' : 'smooth'
        });
      }
    };

    root.querySelectorAll('[data-ct-image-index]').forEach((button) => {
      button.addEventListener('click', () => setActiveImage(Number(button.dataset.ctImageIndex || 0)));
    });

    if (galleryTrack && slides.length > 1) {
      let touchStartX = 0;
      let touchStartY = 0;
      let touchLastX = 0;
      let touchLastY = 0;
      let isImageSwipe = false;

      galleryTrack.addEventListener('touchstart', (event) => {
        const touch = event.touches[0];
        if (!touch) return;
        touchStartX = touch.clientX;
        touchStartY = touch.clientY;
        touchLastX = touchStartX;
        touchLastY = touchStartY;
        isImageSwipe = false;
      }, { passive: true });

      galleryTrack.addEventListener('touchmove', (event) => {
        const touch = event.touches[0];
        if (!touch) return;
        touchLastX = touch.clientX;
        touchLastY = touch.clientY;

        const deltaX = touchLastX - touchStartX;
        const deltaY = touchLastY - touchStartY;
        if (Math.abs(deltaY) > 8 || Math.abs(deltaX) > 8) {
          isImageSwipe = true;
          event.preventDefault();
        }
      }, { passive: false });

      galleryTrack.addEventListener('touchend', () => {
        if (!isImageSwipe) return;
        const deltaX = touchLastX - touchStartX;
        const deltaY = touchLastY - touchStartY;
        const isVertical = Math.abs(deltaY) >= Math.abs(deltaX);
        const swipeAmount = isVertical ? deltaY : deltaX;

        suppressZoomUntil = Date.now() + 450;
        if (Math.abs(swipeAmount) > 42) {
          const direction = swipeAmount < 0 ? 1 : -1;
          setActiveImage(activeImageIndex + direction);
        }
      });

      galleryTrack.addEventListener('scroll', () => {
        if (!isMobileGallery() || !galleryTrack.clientWidth) return;
        const nextIndex = Math.round(galleryTrack.scrollLeft / galleryTrack.clientWidth);
        if (nextIndex !== activeImageIndex) setActiveImage(nextIndex, { skipScroll: true });
      }, { passive: true });
    }

    colorButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const urls = button.dataset.ctGallery.split('|').filter(Boolean);
        const label = button.dataset.ctColorLabelValue || '';

        colorButtons.forEach((item) => {
          const isActive = item === button;
          item.classList.toggle('is-active', isActive);
          item.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });

        if (colorLabel) colorLabel.textContent = label;
        if (mobileColor) mobileColor.value = label;

        galleryImages.forEach((image, index) => {
          const nextUrl = urls[index] || urls[0];
          if (!nextUrl) return;
          image.src = nextUrl;
          image.alt = productTitle + ' - ' + label + ' - Imagen ' + String(index + 1);
        });

        thumbImages.forEach((image, index) => {
          const nextUrl = urls[index] || urls[0];
          if (nextUrl) image.src = nextUrl;
        });

        setActiveImage(0);
      });
    });

    if (mobileColor) {
      mobileColor.addEventListener('change', () => {
        const match = colorButtons.find((button) => button.dataset.ctColorLabelValue === mobileColor.value);
        if (match) match.click();
      });
    }

    let selectedSize = '';
    let selectedVariantId = '';

    sizeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (button.disabled) return;
        selectedSize = button.dataset.ctSizeOption || '';
        selectedVariantId = button.dataset.ctVariantId || '';
        sizeButtons.forEach((item) => {
          const isActive = item === button;
          item.classList.toggle('is-active', isActive);
          item.setAttribute('aria-checked', isActive ? 'true' : 'false');
        });
        if (addButton) {
          const productUrl = addButton.dataset.ctProductUrl || addButton.href;
          addButton.href = selectedVariantId ? productUrl + '?variant=' + selectedVariantId : productUrl;
        }
        if (sizeError) sizeError.hidden = true;
      });
    });

    if (addButton && sizeButtons.length) {
      addButton.addEventListener('click', (event) => {
        if (addButton.getAttribute('aria-disabled') === 'true') {
          event.preventDefault();
          if (waitlistEmail) waitlistEmail.focus();
          return;
        }
        if (selectedSize) return;
        event.preventDefault();
        if (sizeError) sizeError.hidden = false;
        const firstAvailable = sizeButtons.find((button) => !button.disabled);
        if (firstAvailable) firstAvailable.focus();
      });
    }

    if (description && descriptionToggle) {
      const syncDescriptionToggle = () => {
        if (!descriptionText) return;
        const wasOpen = description.classList.contains('is-open');
        description.classList.remove('is-open');
        const canExpand = descriptionText.scrollHeight > descriptionText.clientHeight + 2;

        descriptionToggle.hidden = !canExpand;
        if (canExpand && wasOpen) description.classList.add('is-open');
        if (!canExpand) descriptionToggle.setAttribute('aria-expanded', 'false');
      };

      window.requestAnimationFrame(syncDescriptionToggle);
      window.addEventListener('resize', syncDescriptionToggle);

      descriptionToggle.addEventListener('click', () => {
        const isOpen = description.classList.toggle('is-open');
        descriptionToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    }

    if (openSize && closeSize && sizeModal) {
      openSize.addEventListener('click', () => {
        if (typeof sizeModal.showModal === 'function') sizeModal.showModal();
      });
      closeSize.addEventListener('click', () => sizeModal.close());
      sizeModal.addEventListener('click', (event) => {
        if (event.target === sizeModal) sizeModal.close();
      });
    }

    root.querySelectorAll('[data-ct-zoom-image]').forEach((button) => {
      button.addEventListener('click', (event) => {
        if (Date.now() < suppressZoomUntil) {
          event.preventDefault();
          return;
        }
        const image = button.querySelector('img');
        if (!image || !zoomDialog || !zoomedImage || typeof zoomDialog.showModal !== 'function') return;
        zoomedImage.src = image.src;
        zoomedImage.alt = image.alt;
        zoomDialog.showModal();
      });
    });

    if (closeZoom && zoomDialog) {
      closeZoom.addEventListener('click', () => zoomDialog.close());
      zoomDialog.addEventListener('click', (event) => {
        if (event.target === zoomDialog) zoomDialog.close();
      });
    }

    root.querySelectorAll('[data-ct-copy]').forEach((button) => {
      button.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(button.dataset.ctCopy || button.textContent.trim());
        } catch (error) {}
      });
    });
  })();
</script>

