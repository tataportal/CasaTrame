        <span>S/ 109</span>
      </a>
      <a class="ct-mm-product" href="/products/polo-cuello-alto-ushuaia">
        <img src="{{ 'polo-cuello-alto-ushuaia-negro-modelo-01.webp' | asset_url }}" alt="Polo Ushuaia Cuello Alto" width="1200" height="1500" loading="lazy">
        <span>Polo Ushuaia Cuello Alto</span>
        <span>S/ 119</span>
      </a>
      <a class="ct-mm-product" href="/products/polera-cuello-alto-calafate">
        <img src="{{ 'polera-cuello-alto-calafate-verde-modelo-01.webp' | asset_url }}" alt="Polera Cuello Alto Calafate" width="1200" height="1500" loading="lazy">
        <span>Polera Cuello Alto Calafate</span>
        <span>S/ 159</span>
      </a>
      <a class="ct-mm-product" href="/products/jean-wide-leg-corrientes">
        <img src="{{ 'jean-wide-leg-corrientes-denim-claro-modelo-01.webp' | asset_url }}" alt="Jean Wide Leg Corrientes" width="1200" height="1500" loading="lazy">
        <span>Jean Wide Leg Corrientes</span>
        <span>S/ 239</span>
      </a>
    </div>
  </section>

  <dialog class="ct-mm-zoom" data-ct-mm-dialog>
    <button class="ct-mm-zoom__close" type="button" data-ct-mm-close>Cerrar</button>
    <img src="{{ 'polo-cuello-cuadrado-ombu-guinda-modelo-01.webp' | asset_url }}" alt="" width="1200" height="1500" data-ct-mm-zoomed>
  </dialog>
</main>

