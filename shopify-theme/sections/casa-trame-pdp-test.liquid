{% liquid
  assign collection_url = routes.collections_url | append: '/coleccion-otono-invierno-2026'
  assign product_title = section.settings.product_title | default: 'Polo Ombú Cuello Cuadrado'
  assign product_price = section.settings.product_price | default: 'S/ 99'
  assign product_handle = 'polo-cuello-cuadrado-ombu'
%}

{% render 'casa-trame-nav', active: 'collection', collection_url: collection_url %}

<main class="ct-mm-pdp" data-ct-mm-pdp="{{ section.id }}">
  <div class="ct-mm-pdp__shell">
    <section class="ct-mm-gallery" aria-label="Galería de {{ product_title | escape }}">
      <button class="ct-mm-gallery__item" type="button" data-ct-zoom-image>
        <img src="{{ 'polo-cuello-cuadrado-ombu-guinda-modelo-01.webp' | asset_url }}" alt="{{ product_title | escape }} en guinda, vista 1" width="1200" height="1500" data-ct-gallery-image>
      </button>
      <button class="ct-mm-gallery__item" type="button" data-ct-zoom-image>
        <img src="{{ 'polo-cuello-cuadrado-ombu-guinda-modelo-02.webp' | asset_url }}" alt="{{ product_title | escape }} en guinda, vista 2" width="1200" height="1500" data-ct-gallery-image>
      </button>
      <button class="ct-mm-gallery__item" type="button" data-ct-zoom-image>
        <img src="{{ 'polo-cuello-cuadrado-ombu-guinda.webp' | asset_url }}" alt="{{ product_title | escape }} en guinda, prenda" width="1200" height="1500" data-ct-gallery-image>
      </button>
      <button class="ct-mm-gallery__item" type="button" data-ct-zoom-image>
        <img src="{{ 'polo-cuello-cuadrado-ombu-guinda-modelo-03.webp' | asset_url }}" alt="{{ product_title | escape }} en guinda, vista 3" width="1200" height="1500" data-ct-gallery-image>
      </button>
      <button class="ct-mm-gallery__item" type="button" data-ct-zoom-image>
        <img src="{{ 'polo-cuello-cuadrado-ombu-guinda-modelo-04.webp' | asset_url }}" alt="{{ product_title | escape }} en guinda, vista 4" width="1200" height="1500" data-ct-gallery-image>
      </button>
      <button class="ct-mm-gallery__item" type="button" data-ct-zoom-image>
        <img src="{{ 'polo-cuello-cuadrado-ombu-guinda.png' | asset_url }}" alt="{{ product_title | escape }} en guinda, detalle" width="1200" height="1500" data-ct-gallery-image>
      </button>
    </section>

    <aside class="ct-mm-info" aria-labelledby="ct-mm-title-{{ section.id }}">
      <nav class="ct-mm-crumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Inicio</a>
        <span>/</span>
        <a href="{{ collection_url }}">Colección</a>
        <span>/</span>
        <a href="{{ collection_url }}">Polos</a>
      </nav>

      <p class="ct-mm-info__eyebrow">Polos</p>
      <h1 class="ct-mm-info__title" id="ct-mm-title-{{ section.id }}">{{ product_title }}</h1>
      <p class="ct-mm-info__price">{{ product_price }}</p>
      <p class="ct-mm-info__status">Disponible</p>

      <div class="ct-mm-field">
        <div class="ct-mm-field__row">
          <span>Color</span>
          <span data-ct-color-label>Guinda</span>
        </div>
        <div class="ct-mm-swatches" aria-label="Seleccionar color">
          <button
            class="ct-mm-swatch is-active"
            type="button"
            aria-pressed="true"
            data-ct-color-label-value="Guinda"
            data-ct-gallery="{{ 'polo-cuello-cuadrado-ombu-guinda-modelo-01.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-guinda-modelo-02.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-guinda.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-guinda-modelo-03.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-guinda-modelo-04.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-guinda.png' | asset_url }}"
          >
            <span class="ct-mm-swatch__color ct-mm-swatch__color--guinda"></span>
            <span>Guinda</span>
          </button>
          <button
            class="ct-mm-swatch"
            type="button"
            aria-pressed="false"
            data-ct-color-label-value="Negro"
            data-ct-gallery="{{ 'polo-cuello-cuadrado-ombu-negro-modelo-01.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-negro-modelo-02.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-negro.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-negro-modelo-03.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-negro-modelo-04.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-negro.png' | asset_url }}"
          >
            <span class="ct-mm-swatch__color ct-mm-swatch__color--negro"></span>
            <span>Negro</span>
          </button>
          <button
            class="ct-mm-swatch"
            type="button"
            aria-pressed="false"
            data-ct-color-label-value="Blanco"
            data-ct-gallery="{{ 'polo-cuello-cuadrado-ombu-blanco-modelo-01.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-blanco-modelo-02.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-blanco.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-blanco-modelo-03.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-blanco-modelo-04.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-blanco.png' | asset_url }}"
          >
            <span class="ct-mm-swatch__color ct-mm-swatch__color--blanco"></span>
            <span>Blanco</span>
          </button>
          <button
            class="ct-mm-swatch"
            type="button"
            aria-pressed="false"
            data-ct-color-label-value="Azul oscuro"
            data-ct-gallery="{{ 'polo-cuello-cuadrado-ombu-azul-modelo-01.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-azul-modelo-02.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-azul.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-azul-modelo-03.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-azul-modelo-04.webp' | asset_url }}|{{ 'polo-cuello-cuadrado-ombu-azul.png' | asset_url }}"
