{% liquid
  assign collection_url = routes.collections_url | append: '/coleccion-otono-invierno-2026'
  assign product_title = section.settings.product_title | default: 'Abrigo Suede Pampa'
  assign product_price = section.settings.product_price | default: 'S/ 259'
  assign product_handle = 'abrigo-suede-pampa'
  assign pdp_product = all_products[product_handle]
  assign product_is_available = false
  assign size_labels = 'S,M,L,XL' | split: ','
  if pdp_product != blank and pdp_product.available
    assign product_is_available = true
  endif
%}

{% render 'casa-trame-nav', active: 'collection', collection_url: collection_url %}

<main class="ct-mm-pdp" data-ct-mm-pdp="{{ section.id }}">
  <section class="ct-mm-product" aria-label="{{ product_title | escape }}">
    <div class="ct-mm-thumbs" aria-label="Fotos del producto">
      <span class="ct-mm-thumbs__marker"></span>
      <button class="ct-mm-thumb is-active" type="button" aria-label="Ver foto 1" data-ct-image-index="0">
        <img src="{{ 'abrigo-suede-pampa-verde-modelo-01.webp' | asset_url }}" alt="" width="120" height="150">
      </button>
      <button class="ct-mm-thumb" type="button" aria-label="Ver foto 2" data-ct-image-index="1">
        <img src="{{ 'abrigo-suede-pampa-verde-modelo-02.webp' | asset_url }}" alt="" width="120" height="150">
      </button>
      <button class="ct-mm-thumb" type="button" aria-label="Ver foto 3" data-ct-image-index="2">
        <img src="{{ 'abrigo-suede-pampa-verde-modelo-03.webp' | asset_url }}" alt="" width="120" height="150">
      </button>
      <button class="ct-mm-thumb" type="button" aria-label="Ver foto 4" data-ct-image-index="3">
        <img src="{{ 'abrigo-suede-pampa-verde-modelo-04.webp' | asset_url }}" alt="" width="120" height="150">
      </button>
      <button class="ct-mm-thumb" type="button" aria-label="Ver foto 5" data-ct-image-index="4">
        <img src="{{ 'abrigo-suede-pampa-verde-modelo-05.webp' | asset_url }}" alt="" width="120" height="150">
      </button>
      <button class="ct-mm-thumb" type="button" aria-label="Ver foto 6" data-ct-image-index="5">
        <img src="{{ 'abrigo-suede-pampa-verde-modelo-06.webp' | asset_url }}" alt="" width="120" height="150">
      </button>
      <span class="ct-mm-thumbs__marker"></span>
    </div>

    <div class="ct-mm-gallery" aria-live="polite">
      <div class="ct-mm-gallery__track" data-ct-gallery-track>
        <button class="ct-mm-slide is-active" type="button" data-ct-zoom-image>
          <img src="{{ 'abrigo-suede-pampa-verde-modelo-01.webp' | asset_url }}" alt="{{ product_title | escape }} - Imagen 1" width="1200" height="1500" data-ct-gallery-image>
        </button>
        <button class="ct-mm-slide" type="button" data-ct-zoom-image>
          <img src="{{ 'abrigo-suede-pampa-verde-modelo-02.webp' | asset_url }}" alt="{{ product_title | escape }} - Imagen 2" width="1200" height="1500" data-ct-gallery-image>
        </button>
        <button class="ct-mm-slide" type="button" data-ct-zoom-image>
          <img src="{{ 'abrigo-suede-pampa-verde-modelo-03.webp' | asset_url }}" alt="{{ product_title | escape }} - Imagen 3" width="1200" height="1500" data-ct-gallery-image>
        </button>
        <button class="ct-mm-slide" type="button" data-ct-zoom-image>
          <img src="{{ 'abrigo-suede-pampa-verde-modelo-04.webp' | asset_url }}" alt="{{ product_title | escape }} - Imagen 4" width="1200" height="1500" data-ct-gallery-image>
        </button>
        <button class="ct-mm-slide" type="button" data-ct-zoom-image>
          <img src="{{ 'abrigo-suede-pampa-verde-modelo-05.webp' | asset_url }}" alt="{{ product_title | escape }} - Imagen 5" width="1200" height="1500" data-ct-gallery-image>
        </button>
        <button class="ct-mm-slide" type="button" data-ct-zoom-image>
          <img src="{{ 'abrigo-suede-pampa-verde-modelo-06.webp' | asset_url }}" alt="{{ product_title | escape }} - Imagen 6" width="1200" height="1500" data-ct-gallery-image>
        </button>
      </div>
      <div class="ct-mm-pagination" aria-label="Fotos">
        <button class="is-active" type="button" aria-label="Foto 1" data-ct-image-index="0"></button>
        <button type="button" aria-label="Foto 2" data-ct-image-index="1"></button>
        <button type="button" aria-label="Foto 3" data-ct-image-index="2"></button>
        <button type="button" aria-label="Foto 4" data-ct-image-index="3"></button>
        <button type="button" aria-label="Foto 5" data-ct-image-index="4"></button>
        <button type="button" aria-label="Foto 6" data-ct-image-index="5"></button>
      </div>
    </div>

    <aside class="ct-mm-details" aria-labelledby="ct-mm-title-{{ section.id }}">
      <div class="ct-mm-details__inner">
        <nav class="ct-mm-breadcrumb" aria-label="Breadcrumb">
          <a href="{{ collection_url }}">Abrigos</a>
        </nav>

        <h1 class="ct-mm-title" id="ct-mm-title-{{ section.id }}">{{ product_title }}</h1>

        <div class="ct-mm-price-row">
          <p class="ct-mm-price">{{ product_price }}</p>
          <button class="ct-mm-wishlist" type="button" aria-label="Añadir a favoritos">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 3.9C5 3.4 5.4 3 5.9 3h12.2c.5 0 .9.4.9.9v16.2c0 .7-.8 1.1-1.4.7l-5.1-3.4a.9.9 0 0 0-1 0l-5.1 3.4c-.6.4-1.4 0-1.4-.7V3.9Z"/></svg>
          </button>
        </div>

        <div class="ct-mm-color" aria-label="Color">
          <div class="ct-mm-swatches">
            <button
              class="ct-mm-swatch is-active"
              type="button"
              aria-label="Verde Pacay"
              aria-pressed="true"
              data-ct-color-label-value="Verde Pacay"
              data-ct-gallery="{{ 'abrigo-suede-pampa-verde-modelo-01.webp' | asset_url }}|{{ 'abrigo-suede-pampa-verde-modelo-02.webp' | asset_url }}|{{ 'abrigo-suede-pampa-verde-modelo-03.webp' | asset_url }}|{{ 'abrigo-suede-pampa-verde-modelo-04.webp' | asset_url }}|{{ 'abrigo-suede-pampa-verde-modelo-05.webp' | asset_url }}|{{ 'abrigo-suede-pampa-verde-modelo-06.webp' | asset_url }}"
            ><span style="background:#58614b"></span></button>
          </div>
          <p class="ct-mm-color__label" data-ct-color-label>Verde Pacay</p>
        </div>

        <button class="ct-mm-size-guide" type="button" data-ct-open-size>Guía de tallas</button>

        <div class="ct-mm-buybox">
          <select class="ct-mm-select" aria-label="Color" data-ct-mobile-color>
            <option value="Verde Pacay">Verde Pacay</option>
          </select>
          <div class="ct-mm-size-options" role="radiogroup" aria-label="Talla" data-ct-size-group>
            {% for size_label in size_labels %}
              {% liquid
                assign size_available = false
                assign size_variant_id = ''
                if pdp_product != blank
                  for variant in pdp_product.variants
                    if variant.option2 == size_label
                      assign size_variant_id = variant.id
                      if variant.available
                        assign size_available = true
                      endif
                    endif
                  endfor
                endif
              %}
              <button
                class="ct-mm-size-option{% unless size_available %} is-disabled{% endunless %}"
                type="button"
                role="radio"
                aria-checked="false"
                aria-label="{{ size_label }}{% unless size_available %} agotado{% endunless %}"
                data-ct-size-option="{{ size_label }}"
                {% if size_variant_id != blank %}data-ct-variant-id="{{ size_variant_id }}"{% endif %}
                {% unless size_available %}disabled{% endunless %}
              >
                {{ size_label }}
              </button>
            {% endfor %}
          </div>
          <a
            class="ct-mm-add{% unless product_is_available %} is-disabled{% endunless %}"
            href="{% if product_is_available %}/products/{{ product_handle }}{% else %}#{% endif %}"
            data-ct-product-url="/products/{{ product_handle }}"
            {% unless product_is_available %}aria-disabled="true"{% endunless %}
          >
            {% if product_is_available %}Añadir al carrito{% else %}Avísame cuando esté disponible{% endif %}
          </a>
        </div>

        <p class="ct-mm-size-error" hidden data-ct-size-error>{% if product_is_available %}Por favor selecciona una talla disponible{% else %}No hay tallas disponibles por ahora{% endif %}</p>

        {% unless product_is_available %}
          {% assign waitlist_form_id = 'ct-mm-waitlist-' | append: section.id %}
          {% form 'customer', id: waitlist_form_id, class: 'ct-mm-waitlist' %}
            <input type="hidden" name="contact[tags]" value="waitlist, waitlist-{{ product_handle }}">
            <input type="hidden" name="contact[accepts_marketing]" value="true">
            {% if customer %}
              <input type="hidden" name="contact[email]" value="{{ customer.email | escape }}">
              <p class="ct-mm-waitlist__note">Te avisaremos a {{ customer.email }} cuando vuelva a estar disponible.</p>
            {% else %}
              <label class="ct-mm-waitlist__label" for="ct-mm-waitlist-email-{{ section.id }}">Avísame cuando esté disponible</label>
              <input
                class="ct-mm-waitlist__input"
                id="ct-mm-waitlist-email-{{ section.id }}"
                type="email"
                name="contact[email]"
                placeholder="Tu email"
                autocomplete="email"
                required
                data-ct-waitlist-email
              >
            {% endif %}
            <button class="ct-mm-waitlist__button" type="submit">Enviar aviso</button>
            {% if form.posted_successfully? %}
              <p class="ct-mm-waitlist__status" role="status">Listo, te avisaremos cuando vuelva.</p>
            {% elsif form.errors %}
              <p class="ct-mm-waitlist__status ct-mm-waitlist__status--error" role="status">Revisa tu email e inténtalo otra vez.</p>
            {% endif %}
          {% endform %}
        {% endunless %}

        <div class="ct-mm-description">
          <p data-ct-description>
            Abrigo suede verde con forro interno y un botón de bronce en el cuello. Cuenta con bolsillos laterales.
          </p>
          <button type="button" data-ct-description-toggle aria-expanded="false" hidden>
            <span>... Más</span>
            <span>Menos</span>
          </button>
        </div>

        <section class="ct-mm-accordions" aria-label="Información del producto">
          <details>
            <summary>
              <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3h12v18H6zM9 3v18M15 3v18"/></svg> Detalles del producto</span>
              <span></span>
            </summary>
            <div>
              <p>Código de artículo</p>
              <button class="ct-mm-copy" type="button" data-ct-copy="CT-ABR-SUEDE-PAMPA">CT-ABR-SUEDE-PAMPA</button>
              <p>96% policotton / 4% spandex. Forro: 100% poliéster. Lavar en seco, no usar cloro, no usar secadora y no planchar.</p>
            </div>
          </details>
          <details>
            <summary>
              <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7h18v10H3zM7 7V5h10v2M7 17v2h10v-2"/></svg> Envíos y devoluciones</span>
              <span></span>
            </summary>
            <div>
              <p>Envíos a Perú. Cambios y devoluciones según la política vigente de Casa Tramé.</p>
            </div>
          </details>
          <details open>
            <summary>
              <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 8h16v12H4zM12 8v12M4 12h16M7 8c-1.5-2 1.7-4 5 0 3.3-4 6.5-2 5 0"/></svg> Packaging</span>
              <span></span>
            </summary>
            <div>
              <p>Nuestro empaque acompaña la prenda con una presentación sobria, reusable y pensada para proteger el tejido durante el envío.</p>
              <img src="{{ 'casatrame_lookbook_poster.jpg' | asset_url }}" alt="Packaging Casa Tramé" width="1200" height="900" loading="lazy">
            </div>
          </details>
          <details>
            <summary>
              <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> Contacto</span>
              <span></span>
            </summary>
            <div>
              <p>Escríbenos a <a href="mailto:atencionalcliente@casatrame.com">atencionalcliente@casatrame.com</a>. Respondemos lo antes posible en días hábiles.</p>
            </div>
          </details>
        </section>
      </div>
    </aside>
  </section>

  <nav class="ct-mm-bottom-crumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Inicio</a>
    <span>/</span>
    <a href="{{ collection_url }}">Colección</a>
    <span>/</span>
    <span>{{ product_title }}</span>
  </nav>

  <section class="ct-mm-recommendations" aria-labelledby="ct-mm-recs-title-{{ section.id }}">
    <h2 id="ct-mm-recs-title-{{ section.id }}">También te puede gustar</h2>
    <div class="ct-mm-recs__grid">
      <a class="ct-mm-rec" href="/products/blazer-palermo">
        <img src="{{ 'blazer-palermo-beige-modelo-01.webp' | asset_url }}" alt="Blazer Palermo" width="1200" height="1500" loading="lazy">
        <span>Blazer Palermo</span>
        <span>S/ 289</span>
      </a>
      <a class="ct-mm-rec" href="/products/capa-patagonica">
        <img src="{{ 'capa-patagonica-camel-modelo-01.webp' | asset_url }}" alt="Capa Patagónica" width="1200" height="1500" loading="lazy">
        <span>Capa Patagónica</span>
        <span>S/ 477</span>
      </a>
      <a class="ct-mm-rec" href="/products/falda-suede-pampa">
        <img src="{{ 'falda-suede-pampa-verde-modelo-01.webp' | asset_url }}" alt="Falda Suede Pampa" width="1200" height="1500" loading="lazy">
        <span>Falda Suede Pampa</span>
        <span>S/ 139</span>
      </a>
    </div>
  </section>

  <dialog class="ct-mm-modal" data-ct-size-modal>
    <button class="ct-mm-modal__close" type="button" data-ct-close-size aria-label="Cerrar">Cerrar</button>
    <div class="ct-mm-modal__body">
      <h2>Encuentra tu talla</h2>
      <table>
        <thead>
          <tr>
            <th>Prenda</th>
            <th>Tallas disponibles</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>{{ product_title }}</td>
            <td>S / M / L / XL</td>
          </tr>
        </tbody>
      </table>
    </div>
  </dialog>

  <dialog class="ct-mm-zoom" data-ct-mm-dialog>
    <button class="ct-mm-modal__close" type="button" data-ct-mm-close aria-label="Cerrar">Cerrar</button>
    <img src="{{ 'abrigo-suede-pampa-verde-modelo-01.webp' | asset_url }}" alt="" width="1200" height="1500" data-ct-mm-zoomed>
  </dialog>
</main>

<style>
  #shopify-section-{{ section.id }} .ct-mm-pdp {
    min-height: 100vh;
    padding-top: var(--nav-h);
    background: #fff;
    color: #1a1a1a;
    font-family: var(--body);
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .ct-mm-pdp *,
  #shopify-section-{{ section.id }} .ct-mm-pdp *::before,
  #shopify-section-{{ section.id }} .ct-mm-pdp *::after {
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .ct-mm-product {
    width: 100%;
    min-height: calc(100vh - var(--nav-h));
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: start;
    gap: 0;
    padding: 3rem 0 3.5rem;
  }

  #shopify-section-{{ section.id }} .ct-mm-thumbs {
    position: sticky;
    top: calc(var(--nav-h) + 1.4rem);
    min-height: calc(100vh - var(--nav-h) - 2.8rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  #shopify-section-{{ section.id }} .ct-mm-thumbs__marker {
    width: 1px;
    height: 2.25rem;
    background: #c8c8c8;
  }

  #shopify-section-{{ section.id }} .ct-mm-thumb {
    width: 4.2rem;
    aspect-ratio: 2 / 3;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 0;
    background: #f7f7f2;
    opacity: 0.62;
  }

  #shopify-section-{{ section.id }} .ct-mm-thumb.is-active {
    border-color: #1a1a1a;
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .ct-mm-thumb img,
  #shopify-section-{{ section.id }} .ct-mm-slide img,
  #shopify-section-{{ section.id }} .ct-mm-rec img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .ct-mm-gallery {
    position: sticky;
    top: calc(var(--nav-h) + 3rem);
    min-height: calc(100vh - var(--nav-h) - 6.5rem);
    display: grid;
    justify-items: center;
    align-items: start;
  }

  #shopify-section-{{ section.id }} .ct-mm-gallery__track {
    width: min(100%, 56rem);
    aspect-ratio: 2 / 3;
    position: relative;
    background: #f7f7f2;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .ct-mm-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: #f7f7f2;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.22s ease, visibility 0.22s ease;
  }

  #shopify-section-{{ section.id }} .ct-mm-slide.is-active {
    opacity: 1;
    visibility: visible;
  }

  #shopify-section-{{ section.id }} .ct-mm-pagination {
    display: none;
  }

  #shopify-section-{{ section.id }} .ct-mm-details {
    min-height: calc(100vh - var(--nav-h) - 6.5rem);
    display: flex;
    justify-content: center;
    padding-top: 0;
  }

  #shopify-section-{{ section.id }} .ct-mm-details__inner {
    width: min(100%, 23rem);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1.05rem;
  }

  #shopify-section-{{ section.id }} .ct-mm-breadcrumb,
  #shopify-section-{{ section.id }} .ct-mm-title,
  #shopify-section-{{ section.id }} .ct-mm-price,
  #shopify-section-{{ section.id }} .ct-mm-color,
  #shopify-section-{{ section.id }} .ct-mm-description {
    text-align: center;
  }

  #shopify-section-{{ section.id }} .ct-mm-breadcrumb a {
    color: #1a1a1a;
    font-size: 0.92rem;
    text-decoration: underline;
    text-underline-offset: 0.18rem;
  }

  #shopify-section-{{ section.id }} .ct-mm-title {
    margin: 0;
    font-family: var(--body);
    font-size: 1.08rem;
    font-weight: 400;
    line-height: 1.25;
  }

  #shopify-section-{{ section.id }} .ct-mm-price-row {
    min-height: 2.5rem;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.7rem;
  }

  #shopify-section-{{ section.id }} .ct-mm-price {
    margin: 0;
    font-size: 1rem;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .ct-mm-wishlist {
    width: 2.4rem;
    height: 2.4rem;
    display: inline-grid;
    place-items: center;
    padding: 0;
    border: 0;
    color: #1a1a1a;
  }

  #shopify-section-{{ section.id }} .ct-mm-wishlist svg {
    width: 1.25rem;
    height: 1.25rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  #shopify-section-{{ section.id }} .ct-mm-swatches {
    display: flex;
    justify-content: center;
    gap: 0.82rem;
    min-height: 1.6rem;
  }

  #shopify-section-{{ section.id }} .ct-mm-swatch {
    width: 1.35rem;
    height: 1.35rem;
    padding: 0.18rem;
    border: 1px solid transparent;
    border-radius: 999px;
    background: transparent;
  }

  #shopify-section-{{ section.id }} .ct-mm-swatch.is-active {
    border-color: #1a1a1a;
  }

  #shopify-section-{{ section.id }} .ct-mm-swatch span {
    display: block;
    width: 100%;
    height: 100%;
    border: 1px solid #bdbdbd;
    border-radius: inherit;
  }

  #shopify-section-{{ section.id }} .ct-mm-color__label {
    margin: 0.35rem 0 0;
    font-size: 0.94rem;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .ct-mm-size-guide {
    justify-self: center;
    align-self: center;
    padding: 0;
    border: 0;
    border-bottom: 1px solid currentColor;
    border-radius: 0;
    color: #1a1a1a;
    font-size: 0.92rem;
    line-height: 1.25;
  }

  #shopify-section-{{ section.id }} .ct-mm-buybox {
    display: grid;
    gap: 0.55rem;
  }

  #shopify-section-{{ section.id }} .ct-mm-select[data-ct-mobile-color] {
    display: none;
  }

  #shopify-section-{{ section.id }} .ct-mm-size-options {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.45rem;
  }

  #shopify-section-{{ section.id }} .ct-mm-size-option {
    position: relative;
    aspect-ratio: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid #d1d1cc;
    border-radius: 0;
    background: #fff;
    color: #1a1a1a;
    font: inherit;
    font-size: 0.96rem;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .ct-mm-size-option.is-active {
    border-color: #1a1a1a;
    background: #1a1a1a;
    color: #fff;
  }

  #shopify-section-{{ section.id }} .ct-mm-size-option:disabled {
    border-color: rgba(26, 26, 26, 0.16);
    background: rgba(26, 26, 26, 0.035);
    color: rgba(26, 26, 26, 0.32);
    cursor: not-allowed;
  }

  #shopify-section-{{ section.id }} .ct-mm-size-option:disabled::after {
    content: "";
    position: absolute;
    left: -18%;
    top: 50%;
    width: 136%;
    height: 1px;
    background: rgba(26, 26, 26, 0.36);
    transform: rotate(-38deg);
    pointer-events: none;
  }

