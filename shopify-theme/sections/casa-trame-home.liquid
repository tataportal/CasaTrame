{% liquid
  assign collection_url = routes.all_products_collection_url
  if section.settings.featured_collection != blank
    assign collection_url = section.settings.featured_collection.url
  endif

  assign vestidor_url = section.settings.vestidor_url
  if vestidor_url == blank
    assign vestidor_url = '/pages/vestidor'
  endif

  assign favorites_url = section.settings.favorites_url
  if favorites_url == blank
    assign favorites_url = '/pages/favoritos'
  endif

  assign concept_png_asset = 'brand_image.png'
  assign concept_webp_asset = 'brand_image.webp'
  assign vestidor_asset = 'app.png'
  assign vestidor_webp_asset = 'app.webp'
%}

{% render 'casa-trame-nav', active: 'about', collection_url: collection_url, transparent_on_hero: true %}

<section class="hero" id="hero">
  <div class="hero__video">
    <video class="hero__video-el" autoplay muted loop playsinline preload="metadata" poster="{{ 'trame_home_lookbook_poster_horizontal.jpg' | asset_url }}">
      <source src="{{ 'trame_home_lookbook_vertical.mp4' | asset_url }}" type="video/mp4" media="(max-width: 768px)">
      <source src="{{ 'trame_home_lookbook_horizontal.mp4' | asset_url }}" type="video/mp4">
    </video>
  </div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <a href="{{ collection_url }}" class="hero__cta">
      {{ section.settings.hero_cta_label }}
      <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<section class="brand-statement" id="conocenos">
  <div class="brand-statement__content">
    <h2 class="brand-statement__title">{{ section.settings.brand_title | escape | newline_to_br }}</h2>
    <p class="brand-statement__text">
      {{ section.settings.brand_text | escape | newline_to_br }}
    </p>
  </div>
  <div class="brand-statement__img">
    <picture class="brand-statement__picture">
      <source srcset="{{ concept_webp_asset | asset_url }}" type="image/webp">
      <img src="{{ concept_png_asset | asset_url }}" alt="{{ section.settings.brand_title | escape }}" width="1164" height="950" loading="lazy">
    </picture>
  </div>
</section>

<section class="collection-section">
  <h3 class="collection-section__title">{{ section.settings.collection_title }}</h3>
  <div class="collection-grid">
    <div class="collection-grid__track">
      {% for block in section.blocks %}
        {% assign card_url = block.settings.link %}
        {% if card_url == blank %}
          {% assign card_url = collection_url %}
        {% endif %}
        <a href="{{ card_url }}" class="collection-card" {{ block.shopify_attributes }}>
          <div class="collection-card__img">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {% elsif block.settings.asset_fallback != blank %}
              <img src="{{ block.settings.asset_fallback | asset_url }}" alt="{{ block.settings.title | escape }}" width="1200" height="1500" loading="lazy">
            {% endif %}
          </div>
          <span class="collection-card__name">{{ block.settings.title }}</span>
        </a>
      {% endfor %}
    </div>
    <button class="carousel-arrow carousel-arrow--left" type="button" aria-label="Anterior">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </button>
    <button class="carousel-arrow carousel-arrow--right" type="button" aria-label="Siguiente">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>
  </div>
  <div class="collection-section__cta">
    <a href="{{ collection_url }}" class="btn-outline">
      {{ section.settings.collection_cta_label }}
      <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<section class="vestidor">
  <h2 class="vestidor__title">{{ section.settings.vestidor_title | escape | newline_to_br }}</h2>
  <p class="vestidor__subtitle">
    {{ section.settings.vestidor_text | escape | newline_to_br }}
  </p>
  <div class="vestidor__mockup">
    {% if section.settings.vestidor_image != blank %}
      <img
        src="{{ section.settings.vestidor_image | image_url: width: 1800 }}"
        alt="{{ section.settings.vestidor_image.alt | default: section.settings.vestidor_title | escape }}"
        width="{{ section.settings.vestidor_image.width }}"
        height="{{ section.settings.vestidor_image.height }}"
        loading="lazy"
      >
    {% else %}
      <picture>
        <source srcset="{{ vestidor_webp_asset | asset_url }}" type="image/webp">
        <img src="{{ vestidor_asset | asset_url }}" alt="{{ section.settings.vestidor_title | escape }}" width="1904" height="805" loading="lazy">
      </picture>
    {% endif %}
  </div>
  <div class="collection-section__cta">
    <a href="{{ vestidor_url }}" class="btn-outline">
      {{ section.settings.vestidor_cta_label }}
      <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<section class="newsletter">
  <div
    class="newsletter__bg"
    {% if section.settings.newsletter_bg != blank %}
      style="--newsletter-bg-image: url('{{ section.settings.newsletter_bg | image_url: width: 2200 }}');"
    {% endif %}
  ></div>
  <div class="newsletter__content">
    <h2 class="newsletter__title">{{ section.settings.newsletter_title | escape | newline_to_br }}</h2>
    {% form 'customer', class: 'newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="hidden" name="contact[accepts_marketing]" value="true">
      <div class="newsletter__row">
        <input class="newsletter__input" type="email" name="contact[email]" placeholder="{{ section.settings.newsletter_placeholder }}" value="{{ form.email }}" required>
        <button class="newsletter__submit" type="submit">{{ section.settings.newsletter_button_label }}</button>
      </div>
      <p class="newsletter__legal-tip">{{ section.settings.newsletter_legal_tip }}</p>
      {% if form.posted_successfully? %}
        <p class="newsletter__status" role="status">{{ section.settings.newsletter_success_message }}</p>
      {% endif %}
      {% if form.errors %}
        <div class="newsletter__errors">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}
    {% endform %}
  </div>
  {% render 'casa-trame-footer',
    brand_text: section.settings.footer_brand_text,
    bottom_text: section.settings.footer_bottom_text,
    social_heading: section.settings.social_heading,
    facebook_url: 'https://www.facebook.com/people/Casa-Tram%C3%A9/61590043711199/',
    instagram_url: 'https://www.instagram.com/casa.trame/',
    tiktok_url: 'https://www.tiktok.com/@casa.trame',
    info_heading: section.settings.info_heading,
    help_heading: section.settings.help_heading,
    info_menu: section.settings.footer_info_menu,
    help_menu: section.settings.footer_help_menu,
    about_label: section.settings.about_label,
    about_url: '#conocenos'
  %}
</section>

