{% liquid
  assign collection_url = routes.collections_url | append: '/coleccion-otono-invierno-2026'
  assign about_url = routes.root_url | append: '#conocenos'
  assign vestidor_url = '/pages/vestidor'
  assign favorites_url = '/pages/favoritos'
%}

<nav class="nav nav--catalog" id="mainNav">
  <div class="nav__inner">
    <div class="nav__left" id="navLinks">
      <a href="{{ collection_url }}">Colección</a>
      <a href="{{ about_url }}">Conócenos</a>
      <a href="{{ vestidor_url }}">Vestidor™</a>
    </div>
    <button class="nav__hamburger" type="button" onclick="toggleMobileMenu()" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>
    <a href="{{ routes.root_url }}" class="nav__logo">
      <img src="{{ 'trame_horizontal-black.svg' | asset_url }}" alt="{{ shop.name | escape }}" width="1115" height="142">
    </a>
    <div class="nav__right">
      <a href="{{ routes.search_url }}" title="Buscar">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </a>
      <a href="{{ routes.account_url }}" title="Cuenta">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="{{ favorites_url }}" title="Favoritos">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" title="Carrito" class="nav__cart">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        {% if cart.item_count > 0 %}<span class="nav__cart-dot"></span>{% endif %}
      </a>
    </div>
  </div>
</nav>

<div class="nav__mobile-menu" id="mobileMenu">
  <a href="{{ collection_url }}">Colección</a>
  <a href="{{ about_url }}">Conócenos</a>
  <a href="{{ vestidor_url }}">Vestidor™</a>
  <hr>
  <a href="{{ favorites_url }}">Favoritos</a>
  <a href="{{ routes.search_url }}">Buscar</a>
  <a href="{{ routes.cart_url }}">Carrito</a>
</div>

<main class="cart-page">
  <header class="cart-page__header">
    <p class="cart-page__kicker">Compra</p>
    <h1>Carrito</h1>
  </header>

  {% if cart.item_count > 0 %}
    <form class="cart-page__form" action="{{ routes.cart_url }}" method="post" novalidate>
      <div class="cart-page__items">
        {% for item in cart.items %}
          <article class="cart-item">
            <a class="cart-item__media" href="{{ item.url }}">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 360 }}" alt="{{ item.image.alt | default: item.product.title | escape }}" width="180" height="225" loading="lazy">
              {% endif %}
            </a>
            <div class="cart-item__details">
              <a class="cart-item__title" href="{{ item.url }}">{{ item.product.title }}</a>
              {% unless item.variant.title == 'Default Title' %}
                <div class="cart-item__variant">{{ item.variant.title }}</div>
              {% endunless %}
              {% if item.properties != empty %}
                <dl class="cart-item__properties">
                  {% for property in item.properties %}
                    {% assign property_first_char = property.first | slice: 0 %}
                    {% unless property.last == blank or property_first_char == '_' %}
                      <div>
                        <dt>{{ property.first }}</dt>
                        <dd>{{ property.last }}</dd>
                      </div>
                    {% endunless %}
                  {% endfor %}
                </dl>
              {% endif %}
              <a class="cart-item__remove" href="{{ item.url_to_remove }}">Eliminar</a>
            </div>
            <div class="cart-item__qty">
              <label for="Quantity-{{ forloop.index }}">Cantidad</label>
              <input id="Quantity-{{ forloop.index }}" type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" inputmode="numeric">
            </div>
            <div class="cart-item__price">
              <span>{{ item.final_line_price | money }}</span>
              {% if item.original_line_price != item.final_line_price %}
                <s>{{ item.original_line_price | money }}</s>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>

      <aside class="cart-page__summary">
        <div class="cart-page__summary-row">
          <span>Subtotal</span>
          <strong>{{ cart.total_price | money }}</strong>
        </div>
        <p>Envíos, cambios y devoluciones se confirman antes del pago final.</p>
        <button class="cart-page__checkout" type="submit" name="checkout">Checkout</button>
        <button class="cart-page__update" type="submit" name="update">Actualizar carrito</button>
        <a class="cart-page__continue" href="{{ collection_url }}">Seguir comprando</a>
      </aside>
    </form>
  {% else %}
    <section class="cart-page__empty">
      <p>Tu carrito está vacío.</p>
      <a class="cart-page__checkout" href="{{ collection_url }}">Ver colección</a>
    </section>
  {% endif %}
</main>

{% schema %}
{
  "name": "Casa Trame Cart",
  "settings": []
}
{% endschema %}
