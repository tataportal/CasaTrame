    @media (min-width: 1440px) {
      .ct-v {
        --v-title: clamp(15px, calc(35px - 1.0417vw), 20px);
        --v-body: clamp(13px, calc(29px - 0.8333vw), 17px);
        --v-small: clamp(12px, calc(28px - 0.8333vw), 16px);
        --v-action: clamp(12px, calc(24px - 0.625vw), 15px);
        grid-template-columns:
          minmax(clamp(210px, calc(370px - 8.3333vw), 250px), clamp(300px, calc(480px - 9.375vw), 345px))
          minmax(clamp(292px, calc(684px - 20.4167vw), 390px), 1fr)
          minmax(clamp(255px, calc(595px - 17.7083vw), 340px), clamp(302px, calc(706px - 21.0417vw), 403px));
      }
      .ct-v__section-head {
        padding: clamp(0.75rem, calc(2rem - 0.0651vw), 1.063rem) clamp(1rem, calc(2rem - 0.0521vw), 1.25rem);
      }
      .ct-v__items {
        gap: clamp(0.3rem, calc(0.7rem - 0.0208vw), 0.4rem);
        padding: 0 clamp(0.6rem, calc(1.4rem - 0.0417vw), 0.8rem) clamp(0.75rem, calc(1.75rem - 0.0521vw), 1rem);
      }
