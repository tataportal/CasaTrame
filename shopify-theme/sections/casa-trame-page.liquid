      <section class="ct-favorites-empty" data-favorites-empty aria-label="Favoritos guardados">
        <div>
          <h2 class="ct-favorites-empty__title">Aún no tienes favoritos guardados.</h2>
          <p class="ct-simple-page__text">Explora la colección y vuelve aquí cuando tengas prendas marcadas.</p>
        </div>
        <a class="ct-favorites-empty__cta" href="{{ collection_url }}">Ver colección</a>
      </section>
    </div>
  </main>
  <script>
    (() => {
      const favoriteStorageKey = 'casa-trame-favorites-v1';
      const allFavorites = [
        {% for product in vestidor_collection.products %}
          {% liquid
            assign color_option = blank
            assign color_option_position = 0
            for option in product.options_with_values
              assign option_name = option.name | downcase
              if option_name contains 'color' or option_name contains 'colour'
                assign color_option = option
                assign color_option_position = forloop.index
              endif
            endfor
          %}
          {% if color_option != blank %}
            {% for color_value in color_option.values %}
              {% liquid
                assign color_slug = color_value | handleize
                assign favorite_id = product.id | append: '-' | append: color_slug
                assign color_display = color_value
                if color_display == 'Black'
                  assign color_display = 'Negro'
                endif
                assign thumb_color_slug = color_slug
                if thumb_color_slug == 'black'
                  assign thumb_color_slug = 'negro'
                elsif thumb_color_slug == 'verde-pacay' or thumb_color_slug == 'verde-botella'
                  assign thumb_color_slug = 'verde'
                elsif thumb_color_slug == 'gris-oscuro'
                  assign thumb_color_slug = 'gris'
                elsif thumb_color_slug == 'azul-oscuro'
                  assign thumb_color_slug = 'azul'
                elsif thumb_color_slug == 'perla'
                  assign thumb_color_slug = 'blanco'
                endif
                assign thumb_asset_name = product.handle | append: '-' | append: thumb_color_slug | append: '.webp'
                if product.handle == 'polera-cuello-alto-calafate' and thumb_color_slug == 'verde'
                  assign thumb_asset_name = 'polera-cuello-alto-calafate-verde.png'
                endif
                assign variant_url = product.url
                for variant in product.variants
                  assign variant_color = ''
                  case color_option_position
                    when 1
                      assign variant_color = variant.option1
                    when 2
                      assign variant_color = variant.option2
                    when 3
                      assign variant_color = variant.option3
                  endcase
                  if variant_color == color_value
                    assign variant_url = product.url | append: '?variant=' | append: variant.id
                    break
                  endif
                endfor
              %}
              {
                id: {{ favorite_id | json }},
                title: {{ product.title | json }},
                color: {{ color_display | json }},
                price: {{ product.price | money | json }},
                url: {{ variant_url | json }},
                image: {{ thumb_asset_name | asset_url | json }}
              },
            {% endfor %}
          {% else %}
            {% liquid
              assign favorite_id = product.id
              assign thumb_asset_name = product.handle | append: '.webp'
            %}
            {
              id: {{ favorite_id | json }},
              title: {{ product.title | json }},
              color: '',
              price: {{ product.price | money | json }},
              url: {{ product.url | json }},
              image: {{ thumb_asset_name | asset_url | json }}
            },
          {% endif %}
        {% endfor %}
      ];
      const grid = document.querySelector('[data-favorites-grid]');
      const empty = document.querySelector('[data-favorites-empty]');

      function escapeHtml(value) {
        return String(value || '').replace(/[&<>"']/g, (char) => ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#039;'
        }[char]));
      }

      function readFavorites() {
        try {
          const parsed = JSON.parse(localStorage.getItem(favoriteStorageKey) || '[]');
          return Array.isArray(parsed) ? parsed.map(String) : [];
        } catch (error) {
          return [];
        }
      }

      function writeFavorites(ids) {
        localStorage.setItem(favoriteStorageKey, JSON.stringify(Array.from(new Set(ids.map(String)))));
        window.dispatchEvent(new CustomEvent('ct:favorites-changed'));
      }

      function renderFavorites() {
        if (!grid || !empty) return;
        const ids = readFavorites();
        const idSet = new Set(ids);
        const items = allFavorites.filter((item) => idSet.has(String(item.id)));
        grid.hidden = items.length === 0;
        empty.hidden = items.length > 0;
        grid.innerHTML = items.map((item) => `
          <article class="ct-favorite-card">
            <a class="ct-favorite-card__image" href="${item.url}">
              <img src="${item.image}" alt="${escapeHtml(item.title)}" loading="lazy">
            </a>
            <a class="ct-favorite-card__meta" href="${item.url}">
              <span>${escapeHtml(item.title)}</span>
              ${item.color ? `<span class="ct-favorite-card__color">${escapeHtml(item.color)}</span>` : ''}
              <span class="ct-favorite-card__price">${escapeHtml(item.price)}</span>
            </a>
            <button class="ct-favorite-card__remove" type="button" data-remove-favorite="${escapeHtml(item.id)}" aria-label="Quitar ${escapeHtml(item.title)} de favoritos">×</button>
          </article>
        `).join('');
        grid.querySelectorAll('[data-remove-favorite]').forEach((button) => {
          button.addEventListener('click', () => {
            writeFavorites(readFavorites().filter((id) => id !== String(button.dataset.removeFavorite)));
            renderFavorites();
          });
        });
      }

      renderFavorites();
      window.addEventListener('storage', (event) => {
        if (event.key === favoriteStorageKey) renderFavorites();
      });
      window.addEventListener('ct:favorites-changed', renderFavorites);
    })();
  </script>
