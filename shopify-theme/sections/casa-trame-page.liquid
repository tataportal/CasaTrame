{% liquid
  assign collection_url = routes.collections_url | append: '/coleccion-otono-invierno-2026'
  assign vestidor_collection = collections['coleccion-otono-invierno-2026']
%}

{% if page.handle == 'vestidor' %}
  <style>
    .ct-v {
      --nav-h: 6.667rem;
      --line: #e4e0da;
      --text: #111;
      --muted: #6f6a61;
      --v-title: 20px;
      --v-body: 17px;
      --v-small: 16px;
      --v-action: 15px;
      display: grid;
      grid-template-columns: minmax(250px, 24vw) minmax(390px, 1fr) minmax(340px, 28vw);
      height: 100vh;
      padding-top: var(--nav-h);
      background: #f7f7f7;
      color: var(--text);
      font-family: var(--body);
      overflow: hidden;
    }
    .ct-v button,
    .ct-v select {
      font-family: var(--body);
    }
    .ct-v__panel {
      min-width: 0;
      height: calc(100vh - var(--nav-h));
      overflow: auto;
      border-right: 1px solid var(--line);
      background: #f7f7f7;
    }
    .ct-v__panel--right {
      border-right: 0;
      border-left: 1px solid var(--line);
    }
    .ct-v__section { border-bottom: 1px solid var(--line); }
    .ct-v__section.is-collapsed .ct-v__items {
      display: none;
    }
    .ct-v__section-toggle-icon {
      display: inline-block;
      transition: transform 0.18s ease;
    }
    .ct-v__section.is-collapsed .ct-v__section-toggle-icon {
      transform: rotate(-90deg);
    }
    .ct-v__section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      width: 100%;
      padding: 1.333rem 1.667rem;
      color: var(--text);
      border: 0;
      background: transparent;
      text-align: left;
      cursor: pointer;
    }
    .ct-v__section-title {
      font-family: var(--body);
      font-size: var(--v-title);
      font-weight: 700;
      font-style: normal;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .ct-v__count {
      color: var(--muted);
      font-size: var(--v-small);
      font-weight: 400;
      font-style: normal;
      letter-spacing: 0.06em;
      margin-left: 0.4rem;
    }
    .ct-v__items {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.533rem;
      padding: 0 1rem 1.333rem;
      min-height: 7rem;
    }
    .ct-v__empty-list {
      grid-column: 1 / -1;
      color: var(--muted);
      font-size: var(--v-body);
      font-weight: 400;
      line-height: 1.45;
      padding: 1.333rem 0.333rem;
      font-style: normal;
    }
    .ct-v__catalog-item {
      position: relative;
      min-width: 0;
      padding: 0;
      border: 1px solid transparent;
      background: transparent;
      color: var(--text);
      cursor: pointer;
      text-align: left;
      overflow: hidden;
    }
    .ct-v__catalog-item:hover,
    .ct-v__catalog-item.is-selected {
      border-color: var(--text);
    }
    .ct-v__catalog-item img {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: contain;
      background: #f5f5f5;
    }
    .ct-v__catalog-item span {
      display: block;
      padding-top: 0.333rem;
      font-size: var(--v-small);
      font-weight: 400;
      font-style: normal;
      line-height: 1.2;
      color: var(--muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .ct-v__center {
      min-width: 0;
      height: calc(100vh - var(--nav-h));
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: relative;
    }
    .ct-v__canvas {
      position: relative;
      flex: 1 1 auto;
      min-height: 0;
      background: #fafafa;
      border-bottom: 1px solid var(--line);
      overflow: hidden;
    }
    .ct-v__silhouette {
      position: absolute;
      inset: 0;
      z-index: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      opacity: 0.065;
    }
    .ct-v__empty {
      position: absolute;
      inset: 0;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      color: var(--muted);
      font-size: var(--v-body);
      font-weight: 400;
      font-style: normal;
      text-align: center;
      pointer-events: none;
    }
    .ct-v__empty.is-hidden { display: none; }
    .ct-v__reference-note {
      position: absolute;
      left: 1rem;
      bottom: 5.2rem;
      z-index: 40;
      max-width: 18rem;
      color: var(--muted);
      font-size: var(--v-small);
      font-weight: 500;
      font-style: normal;
      line-height: 1.35;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      pointer-events: none;
    }
    .ct-v__layer {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }
    .ct-v__layer img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      pointer-events: none;
    }
    .ct-v__toolbar {
      position: absolute;
      left: 1rem;
      right: 1rem;
      bottom: 1rem;
      z-index: 40;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      pointer-events: none;
    }
    .ct-v__toolbar-group {
      display: flex;
      align-items: center;
      gap: 0.533rem;
      pointer-events: auto;
    }
    .ct-v__toolbar > .ct-v__btn {
      pointer-events: auto;
    }
    .ct-v__btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      min-height: 44px;
      padding: 0 1.733rem;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.92);
      color: var(--text);
      font-size: var(--v-action);
      font-weight: 500;
      font-style: normal;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      cursor: pointer;
    }
    .ct-v__btn:disabled {
      opacity: 0.35;
      cursor: default;
    }
    .ct-v__btn svg { width: 1rem; height: 1rem; }
    .ct-v__layers {
      flex: 0 0 18rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.45rem;
      padding: 0.7rem;
      background: #f7f7f7;
      overflow-x: hidden;
      overflow-y: auto;
    }
    .ct-v__layers.has-layers {
      justify-content: flex-start;
      align-items: stretch;
    }
    .ct-v__layers-title {
      color: var(--muted);
      font-size: var(--v-small);
      font-weight: 500;
      font-style: normal;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .ct-v__layers.has-layers .ct-v__layers-title { display: none; }
    .ct-v__chip {
      width: 100%;
      flex: 0 0 auto;
      display: grid;
      grid-template-columns: 2.4rem minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.5rem;
      padding: 0.45rem 0.55rem;
      border: 1px solid var(--line);
      background: #fff;
    }
    .ct-v__chip.is-hidden-layer {
      opacity: 0.55;
    }
    .ct-v__chip-thumb {
      width: 2.4rem;
      height: 3rem;
      object-fit: contain;
      background: #f5f5f5;
    }
    .ct-v__chip-name {
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      font-size: var(--v-body);
      font-weight: 400;
      font-style: normal;
    }
    .ct-v__chip-actions {
      display: flex;
      gap: 0.45rem;
      align-items: center;
    }
    .ct-v__chip-btn {
      width: 40px;
      height: 40px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 0;
      background: transparent;
      color: var(--muted);
      cursor: pointer;
    }
    .ct-v__chip-btn:hover {
      background: #f1f1f1;
      color: var(--text);
    }
    .ct-v__chip-btn svg {
      width: 20px;
      height: 20px;
    }
    .ct-v__summary {
      min-height: 100%;
      padding: clamp(1.2rem, 2.2vh, 2rem) 1.733rem;
      display: flex;
      flex-direction: column;
    }
    .ct-v__summary-title,
    .ct-v__saved-title {
      font-size: var(--v-title);
      font-weight: 700;
      font-style: normal;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      margin-bottom: clamp(1rem, 2vh, 2rem);
    }
    .ct-v__summary-list {
      min-height: clamp(8rem, 19vh, 14rem);
      border-bottom: 1px solid var(--line);
      padding-bottom: 1.333rem;
    }
    .ct-v__summary-empty {
      color: var(--muted);
      font-size: var(--v-body);
      font-weight: 400;
      font-style: normal;
      text-align: center;
      padding-top: clamp(1.2rem, 3vh, 2.5rem);
    }
    .ct-v__summary-item {
      display: grid;
      grid-template-columns: 3rem minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.8rem;
      padding: 0.533rem 0;
    }
    .ct-v__summary-info {
      min-width: 0;
    }
    .ct-v__summary-thumb {
      display: block;
      width: 3rem;
      height: 3.75rem;
      background: #f5f5f5;
    }
    .ct-v__summary-item img {
      width: 3rem;
      height: 3.75rem;
      object-fit: contain;
      background: #f5f5f5;
      display: block;
    }
    .ct-v__summary-name {
      font-size: var(--v-body);
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      font-weight: 400;
      font-style: normal;
    }
    .ct-v__summary-name-link {
      display: block;
      color: inherit;
      text-decoration: none;
    }
    .ct-v__summary-thumb:hover,
    .ct-v__summary-name-link:hover {
      opacity: 0.66;
    }
    .ct-v__summary-price {
      font-size: var(--v-body);
      color: var(--muted);
      font-weight: 400;
      font-style: normal;
    }
    .ct-v__size-select {
      width: min(12rem, 100%);
      margin-top: 0.45rem;
      min-height: 40px;
      border: 1px solid var(--line);
      border-radius: 0;
      background: #fff;
      color: var(--text);
      font: inherit;
      font-size: var(--v-action);
      font-weight: 400;
      font-style: normal;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0 1.8rem 0 0.55rem;
      appearance: none;
      background-image:
        linear-gradient(45deg, transparent 50%, var(--muted) 50%),
        linear-gradient(135deg, var(--muted) 50%, transparent 50%);
      background-position:
        calc(100% - 0.9rem) 50%,
        calc(100% - 0.55rem) 50%;
      background-size: 0.35rem 0.35rem, 0.35rem 0.35rem;
      background-repeat: no-repeat;
    }
    .ct-v__size-select:invalid {
      color: var(--muted);
    }
    .ct-v__total {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      padding: 1.333rem 0;
      font-size: var(--v-title);
      font-weight: 700;
      font-style: normal;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-bottom: 1px solid var(--line);
    }
    .ct-v__checkout {
      width: 100%;
      margin-top: 1.333rem;
      min-height: 44px;
      padding: 0 1rem;
      border: 1px solid var(--text);
      background: var(--text);
      color: #fff;
      font-size: var(--v-action);
      font-weight: 500;
      font-style: normal;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      white-space: nowrap;
      cursor: pointer;
    }
    .ct-v__total span:last-child {
      white-space: nowrap;
    }
    .ct-v__checkout:disabled {
      opacity: 0.25;
      cursor: default;
    }
    .ct-v__saved {
      padding-top: clamp(1rem, 2vh, 2rem);
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }
    .ct-v__saved-empty {
      color: var(--muted);
      font-size: var(--v-body);
      font-weight: 400;
      font-style: normal;
      line-height: 1.5;
      text-align: center;
    }
    .ct-v__saved-list {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-content: start;
      gap: 0.533rem;
    }
    .ct-v__saved-list.is-empty {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: clamp(9rem, 22vh, 18rem);
      padding-bottom: 2rem;
    }
    .ct-v__saved-look {
      position: relative;
      aspect-ratio: 4 / 5;
      border: 1px solid transparent;
      background: #fff;
      overflow: hidden;
    }
    .ct-v__saved-look:hover {
      border-color: var(--text);
    }
    .ct-v__saved-look-main {
      display: block;
      width: 100%;
      height: 100%;
      border: 0;
      padding: 0;
      background: transparent;
      color: var(--text);
      cursor: pointer;
    }
    .ct-v__saved-look-thumbs {
      width: 100%;
      height: 100%;
      background: #f5f5f5;
      overflow: hidden;
    }
    .ct-v__saved-look-thumbs img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
    .ct-v__saved-remove {
      position: absolute;
      top: 0.267rem;
      right: 0.267rem;
      z-index: 2;
      width: 36px;
      height: 36px;
      border: 0;
      background: rgba(255, 255, 255, 0.88);
      color: var(--text);
      cursor: pointer;
      font-size: var(--v-small);
      font-weight: 400;
      font-style: normal;
      line-height: 1;
    }
    .ct-v__saved-remove:hover { background: #fff; }
    .ct-v__toast {
      position: fixed;
      left: 50%;
      bottom: 1.6rem;
      z-index: 5000;
      transform: translateX(-50%) translateY(1rem);
      background: #111;
      color: #fff;
      padding: 0.8rem 1.8rem;
      opacity: 0;
      pointer-events: none;
      transition: 0.2s ease;
      font-size: var(--v-small);
      font-weight: 400;
      font-style: normal;
    }
    .ct-v__toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    .ct-v__help-overlay {
      position: fixed;
      inset: 0;
      z-index: 6000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      background: rgba(17, 17, 17, 0.42);
    }
    .ct-v__help-overlay[hidden] { display: none; }
    .ct-v__help-modal {
      width: min(48rem, 100%);
      max-height: min(46rem, calc(100vh - 4rem));
      overflow: auto;
      background: #f7f7f7;
      border: 1px solid var(--line);
      box-shadow: 0 1.6rem 4rem rgba(17, 17, 17, 0.18);
      color: var(--text);
    }
    .ct-v__help-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.333rem;
      padding: 2rem 2rem 1.333rem;
      border-bottom: 1px solid var(--line);
    }
    .ct-v__help-kicker {
      margin-bottom: 0.533rem;
      color: var(--muted);
      font-size: var(--v-small);
      font-weight: 500;
      font-style: normal;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .ct-v__help-title {
      margin: 0;
      font-size: var(--v-title);
      font-weight: 500;
      font-style: normal;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .ct-v__help-close {
      width: 44px;
      height: 44px;
      flex: 0 0 44px;
      border: 1px solid var(--line);
      background: transparent;
      color: var(--text);
      cursor: pointer;
      font-size: var(--v-body);
      font-weight: 400;
      font-style: normal;
      line-height: 1;
    }
    .ct-v__help-body { padding: 1.667rem 2rem 2rem; }
    .ct-v__help-lead {
      margin: 0 0 1.6rem;
      max-width: 34rem;
      color: #4d4945;
      font-size: var(--v-body);
      font-weight: 400;
      font-style: normal;
      line-height: 1.55;
    }
    .ct-v__help-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
      margin-bottom: 1.333rem;
    }
    .ct-v__help-card {
      border: 1px solid var(--line);
      background: #fff;
      padding: 1rem;
    }
    .ct-v__help-card strong {
      display: block;
      margin-bottom: 0.333rem;
      font-size: var(--v-small);
      font-weight: 700;
      font-style: normal;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .ct-v__help-card span {
      display: block;
      color: #5e5954;
      font-size: var(--v-small);
      font-weight: 400;
      font-style: normal;
      line-height: 1.45;
    }
    .ct-v__help-guide-btn {
      width: 100%;
      min-height: 44px;
      border: 1px solid var(--text);
      background: transparent;
      color: var(--text);
      cursor: pointer;
      font-size: var(--v-action);
      font-weight: 500;
      font-style: normal;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .ct-v__help-guide {
      margin-top: 1.333rem;
      padding: 1.333rem;
      border: 1px solid var(--line);
      background: #fff;
    }
    .ct-v__help-guide[hidden] { display: none; }
    .ct-v__help-guide ol {
      margin: 0;
      padding-left: 1.2rem;
    }
    .ct-v__help-guide li {
      margin: 0.667rem 0;
      color: #4d4945;
      font-size: var(--v-small);
      font-weight: 400;
      font-style: normal;
      line-height: 1.45;
    }
    .ct-page {
      min-height: 100vh;
      padding: 12rem min(7vw, 8rem);
      background: #f7f7f7;
      color: #111;
    }
    .ct-page__inner {
      max-width: 72rem;
      margin: 0 auto;
    }
    .ct-page h1 {
      font-family: var(--title-heading);
      font-size: clamp(2.6rem, 5vw, 5rem);
      font-weight: 400;
      margin-bottom: 2rem;
    }
    .ct-page__content {
      font-size: var(--fs-label);
      line-height: 1.7;
    }
    @media (max-width: 980px) {
      .ct-v {
        display: flex;
        flex-direction: column;
        height: auto;
        min-height: 100svh;
        overflow: visible;
      }
      .ct-v__panel,
      .ct-v__panel--right {
        height: auto;
        border: 0;
      }
      .ct-v__center {
        display: contents;
      }
      .ct-v__canvas {
        order: 1;
        flex: 0 0 auto;
        height: max(24rem, calc(60svh - 4rem));
        min-height: 0;
      }
      .ct-v__panel {
        order: 2;
        display: flex;
        flex-wrap: nowrap;
        align-items: stretch;
        gap: 0.667rem;
        height: max(10rem, calc(20svh - 1.333rem));
        padding: 0.667rem 1rem;
        border-top: 1px solid var(--line);
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
      }
      .ct-v__panel:not(.ct-v__panel--right) .ct-v__section {
        display: contents;
      }
      .ct-v__panel:not(.ct-v__panel--right) .ct-v__section-head {
        display: none;
      }
      .ct-v__panel:not(.ct-v__panel--right) .ct-v__items {
        display: contents;
      }
      .ct-v__panel:not(.ct-v__panel--right) .ct-v__items[hidden] {
        display: contents;
      }
      .ct-v__panel:not(.ct-v__panel--right) .ct-v__section.is-collapsed .ct-v__items {
        display: contents;
      }
      .ct-v__catalog-item {
        flex: 0 0 max(8.8rem, calc(16svh - 1rem));
        height: 100%;
        min-height: 0;
        padding: 0;
        background: #f4f3f1;
      }
      .ct-v__catalog-item img {
        height: 100%;
        max-height: none;
        padding: 0.5rem;
      }
      .ct-v__catalog-item span {
        display: none;
      }
      .ct-v__empty-list {
        display: none;
      }
      .ct-v__help-overlay {
        align-items: flex-end;
        padding: 1rem;
      }
      .ct-v__help-modal { max-height: calc(100vh - 2rem); }
      .ct-v__help-head { padding: 1.333rem 1.333rem 1rem; }
      .ct-v__help-body { padding: 1.333rem; }
      .ct-v__help-grid { grid-template-columns: 1fr; }
      .ct-v__panel--right {
        display: block;
        order: 4;
        height: auto;
        padding: 0;
        border-top: 1px solid var(--line);
        border-left: 0;
        overflow: visible;
      }
      .ct-v__summary {
        display: flex;
        flex-direction: column;
        padding: 0;
      }
      .ct-v__saved {
        order: 1;
        min-height: max(10rem, calc(20svh - 1.333rem));
        padding: 1rem;
        border-bottom: 1px solid var(--line);
      }
      .ct-v__saved-title {
        margin-bottom: 0.667rem;
      }
      .ct-v__saved-list {
        min-height: 0;
      }
      .ct-v__saved-empty {
        padding-top: 0.667rem;
      }
      .ct-v__summary-title {
        order: 2;
        padding: 1.667rem 1.667rem 0;
        margin-bottom: 1.333rem;
      }
      .ct-v__summary-list {
        order: 3;
        padding: 0 1.667rem 1.333rem;
