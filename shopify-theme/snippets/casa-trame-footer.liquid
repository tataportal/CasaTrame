{% liquid
  assign footer_variant_class = ''
  if variant == 'light'
    assign footer_variant_class = ' footer--catalog'
  endif

  assign resolved_brand_name = brand_name | default: 'Casa Tramé'
  assign resolved_bottom_text = bottom_text | default: 'Todos los derechos reservados.'
  assign resolved_social_heading = social_heading | default: 'Síguenos'
  assign resolved_info_heading = info_heading | default: 'Info'
  assign resolved_help_heading = help_heading | default: 'Atención'
  assign resolved_about_label = about_label | default: 'Conócenos'
  assign resolved_about_url = about_url | default: '/pages/conocenos'
  assign resolved_facebook_url = facebook_url | default: 'https://www.facebook.com/people/Casa-Tram%C3%A9/61590043711199/'
  assign resolved_instagram_url = instagram_url | default: 'https://www.instagram.com/casa.trame/'
  assign resolved_tiktok_url = tiktok_url | default: 'https://www.tiktok.com/@casa.trame'
%}
{% capture default_brand_text %}Diseñado y producido en Perú{% endcapture %}
{% assign resolved_brand_text = brand_text | default: default_brand_text %}

<footer class="footer{{ footer_variant_class }}">
  <div class="footer__grid">
    <div class="footer__brand">
      <div class="footer__brand-name">{{ resolved_brand_name }}</div>
      <p>{{ resolved_brand_text | escape | newline_to_br }}</p>
    </div>
    <div>
      <h4>{{ resolved_social_heading }}</h4>
      <div class="footer__social-icons" aria-label="{{ resolved_social_heading | escape }}">
        <a href="{{ resolved_facebook_url }}" aria-label="Facebook" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14 8.6V6.9c0-.7.2-1.1 1.1-1.1H17V2.5c-.4-.1-1.6-.2-2.9-.2-2.9 0-4.8 1.7-4.8 4.9v1.4H6.1V12h3.2v9.7H13V12h3.1l.5-3.4H14Z"/>
          </svg>
        </a>
        <a href="{{ resolved_tiktok_url }}" aria-label="TikTok" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M16.6 3c.3 2.4 1.7 3.9 4 4.1v3.4c-1.4.1-2.7-.3-3.9-1.1v6.4c0 4.3-4.7 7-8.4 4.8-4.3-2.5-3.1-9 1.8-9.8.9-.1 1.7 0 2.5.2v3.6c-.4-.2-.9-.3-1.4-.3-2.2.1-2.9 3.1-.9 4.1 1.3.7 2.8-.3 2.8-1.8V3h3.5Z"/>
          </svg>
        </a>
        <a href="{{ resolved_instagram_url }}" aria-label="Instagram" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.3" cy="6.7" r="1.1"/>
          </svg>
        </a>
      </div>
    </div>
    <div>
      <h4>{{ resolved_info_heading }}</h4>
      {% if info_menu != blank %}
        <ul>
          {% for link in info_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      {% else %}
        <ul>
          <li><a href="{{ resolved_about_url }}">{{ resolved_about_label }}</a></li>
          <li><a href="/pages/contact">Contacto</a></li>
        </ul>
      {% endif %}
    </div>
    <div>
      <h4>{{ resolved_help_heading }}</h4>
      {% if help_menu != blank %}
        <ul>
          {% for link in help_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      {% else %}
        <ul>
          <li><a href="/pages/contact">Contacto</a></li>
          <li><a href="/policies/terms-of-service">Términos</a></li>
          <li><a href="/policies/privacy-policy">Privacidad</a></li>
        </ul>
      {% endif %}
    </div>
  </div>
  <div class="footer__bottom">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ resolved_brand_name }}. {{ resolved_bottom_text }}</span>
  </div>
</footer>
